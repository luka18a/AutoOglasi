@{
    ViewData["Title"] = "Početna";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold mt-4">Dobrodošao, @User.Identity!.Name! 👋</h1>
    <p class="lead text-muted">Šta želiš da uradiš danas?</p>
</div>

<div class="row justify-content-center g-4">
    <div class="col-md-5">
        <div class="card h-100 shadow-sm border-0 text-center p-4">
            <div style="font-size: 4rem;">🚘</div>
            <h4 class="mt-3 fw-bold">Lista vozila</h4>
            <p class="text-muted">Pregledaj sve oglase i pronađi vozilo koje tražiš.</p>
            <a href="/Vehicle/Index" class="btn btn-primary mt-auto rounded-pill px-4">Pregledaj</a>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card h-100 shadow-sm border-0 text-center p-4">
            <div style="font-size: 4rem;">➕</div>
            <h4 class="mt-3 fw-bold">Postavi oglas</h4>
            <p class="text-muted">Prodaješ vozilo? Postavi oglas i pronađi kupca.</p>
            <a href="/Vehicle/Create" class="btn btn-success mt-auto rounded-pill px-4">Postavi</a>
        </div>
    </div>
</div>