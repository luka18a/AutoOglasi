<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoOglasi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            .navbar-brand {
                font-size: 1.5rem;
                font-weight: bold;
                letter-spacing: 1px;
            }

            .nav-link {
                font-size: 1rem;
                transition: color 0.2s;
            }

                .nav-link:hover {
                    color: #f8c146 !important;
                }

            .btn-logout {
                border: 1px solid #f87171;
                color: #f87171;
                border-radius: 20px;
                padding: 4px 16px;
                font-size: 0.9rem;
                transition: all 0.2s;
            }

                .btn-logout:hover {
                    background-color: #f87171;
                    color: white;
                }

            .user-badge {
                background-color: #1e3a5f;
                color: #90cdf4;
                border-radius: 20px;
                padding: 4px 14px;
                font-size: 0.9rem;
            }

            body {
                background-color: #f4f6f9;
            }

            .navbar {
                box-shadow: 0 2px 8px rgba(0,0,0,0.3);
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/Home/Index">🚗 AutoOglasi</a>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="navbar-nav ms-auto align-items-center gap-2">
                    <a class="nav-link text-white" href="/Vehicle/Index">🚘 Lista vozila</a>
                    <a class="nav-link text-white" href="/Vehicle/Create">➕ Postavi oglas</a>
                    <span class="user-badge">👤 @User.Identity.Name</span>
                    <a class="btn btn-outline-danger btn-sm rounded-pill px-3" href="/Account/Logout">Odjavi se</a>
                </div>
            }
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>